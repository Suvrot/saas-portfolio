{
  "name": "saas-portfolio-demos",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:ai": "npm --workspace apps/ai-saas-platform run dev",
    "dev:crm": "npm --workspace apps/smart-crm run dev",
    "dev:finance": "npm --workspace apps/finance-dashboard run dev",
    "dev:ecommerce": "npm --workspace apps/ecommerce-platform run dev",
    "dev:chat": "npm --workspace apps/ai-chat-app run dev",
    "dev:tasks": "npm --workspace apps/task-manager run dev",
    "build:ai": "npm --workspace apps/ai-saas-platform run build",
    "build:crm": "npm --workspace apps/smart-crm run build",
    "build:finance": "npm --workspace apps/finance-dashboard run build",
    "build:ecommerce": "npm --workspace apps/ecommerce-platform run build",
    "build:chat": "npm --workspace apps/ai-chat-app run build",
    "build:tasks": "npm --workspace apps/task-manager run build",
    "build": "npm --workspaces --if-present run build",
    "lint": "npm --workspaces --if-present run lint"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@radix-ui/react-slot": "1.3.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "framer-motion": "12.42.2",
    "lucide-react": "1.23.0",
    "next": "^15.5.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tailwind-merge": "3.6.0"
  },
  "devDependencies": {
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "autoprefixer": "10.5.2",
    "eslint": "9.39.4",
    "eslint-config-next": "^15.5.20",
    "postcss": "8.5.16",
    "tailwindcss": "^3.4.17",
    "typescript": "6.0.3"
  }
}